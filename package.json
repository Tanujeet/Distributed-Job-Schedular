{
  "name": "distributed-cron",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "tsx apps/api-service/src/index.ts",
    "dev:scheduler": "tsx apps/scheduler-service/src/index.ts",
    "dev:worker": "tsx apps/worker-service/src/index.ts",
    "dev:web": "next dev apps/web-ui",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:scheduler\" \"npm run dev:worker\" \"npm run dev:web\""
  },
  "dependencies": {
    "bullmq": "^5.70.4",
    "cors": "^2.8.6",
    "cron-parser": "^4.9.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}